rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isParticipant(data) {
      return signedIn() && request.auth.uid in data.participants;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['admin', 'owner', 'super_admin'];
    }

    function isOfferOwnerOrRequestOwner() {
      return signedIn() && (
        resource.data.creator_id == request.auth.uid
        || (
          resource.data.request_id != null
          && exists(/databases/$(database)/documents/requests/$(resource.data.request_id))
          && get(/databases/$(database)/documents/requests/$(resource.data.request_id)).data.customer_id == request.auth.uid
        )
      );
    }

    function conversationParticipantById(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function bidsCountIncrementOnly() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['bids_count', 'updated_at'])
        && request.resource.data.bids_count is int
        && (
          (resource.data.bids_count is int && request.resource.data.bids_count == resource.data.bids_count + 1)
          || (!(resource.data.bids_count is int) && request.resource.data.bids_count == 1)
        );
    }

    function acceptedCreatorCanUpdateRequest() {
      return signedIn()
        && resource.data.accepted_creator_id == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'updated_at',
          'milestone_stage',
          'milestone_log'
        ])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['status'])
          || request.resource.data.status in ['in_progress', 'completed']
        );
    }

    match /profiles/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        || (
          signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['followers_count'])
        )
        || (
          signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['following_count'])
        );
    }

    match /videos/{videoId} {
      allow read: if signedIn() && (
        resource.data.is_published == true
        || isAdmin()
      );
      allow create: if signedIn() && request.resource.data.creator_id == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.creator_id == request.auth.uid
        || request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'likes_count',
          'happy_count',
          'wow_count',
          'sad_count',
          'angry_count',
          'comments_count',
          'shares_count',
          'saves_count',
          'views_count'
        ])
      );
      allow delete: if signedIn() && resource.data.creator_id == request.auth.uid;
    }

    match /video_likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    match /video_reactions/{reactionId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    match /video_saves/{saveId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    match /video_comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.follower_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.follower_id == request.auth.uid;
    }

    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /requests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.customer_id == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.customer_id == request.auth.uid
        || isAdmin()
        || bidsCountIncrementOnly()
        || acceptedCreatorCanUpdateRequest()
      );
      allow delete: if signedIn() && (
        resource.data.customer_id == request.auth.uid
        || isAdmin()
      );
    }

    match /offers/{offerId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.creator_id == request.auth.uid;
      allow update: if isOfferOwnerOrRequestOwner();
    }

    match /orders/{orderId} {
      allow read, write: if false;
    }

    match /conversations/{conversationId} {
      allow read, update, delete: if isParticipant(resource.data);
      allow create: if isParticipant(request.resource.data);
    }

    match /messages/{messageId} {
      allow read: if conversationParticipantById(resource.data.conversation_id);
      allow create: if signedIn()
        && request.resource.data.sender_id == request.auth.uid
        && conversationParticipantById(request.resource.data.conversation_id);
      allow update: if signedIn() && (
        resource.data.sender_id == request.auth.uid
        || (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['deleted_for'])
          && request.auth.uid in request.resource.data.deleted_for
        )
      );
    }

    match /notifications/{notificationId} {
      allow read, update: if isOwner(resource.data.user_id);
      allow create: if signedIn() && request.resource.data.actor_id == request.auth.uid;
    }

    match /livestreams/{streamId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.creator_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.creator_id == request.auth.uid;
    }

    match /livestream_messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /community_posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.author_id == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 2
        && request.resource.data.content.size() <= 600;
      allow update, delete: if signedIn() && (
        resource.data.author_id == request.auth.uid || isAdmin()
      );
    }

    match /subscription_events/{eventId} {
      allow read: if signedIn() && (
        resource.data.user_id == request.auth.uid || isAdmin()
      );
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /measurement_profiles/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /escrow_events/{eventId} {
      allow read: if signedIn() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      allow create: if signedIn()
        && request.resource.data.actor_id == request.auth.uid
        && request.auth.uid in request.resource.data.participants;
      allow update, delete: if false;
    }
  }
}
